# ─── Supabase Configuration ──────────────────────────────────────────────────
# 1. Go to https://supabase.com and create a project (free tier is fine)
# 2. Open Project Settings → API
# 3. Copy "Project URL" and "anon public" key below
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key-here"

# ─── Cloudflare R2 Storage (file uploads) ────────────────────────────────────
# Replace Supabase Storage with Cloudflare R2 for better cost/performance
# 1. Create a Cloudflare account: https://dash.cloudflare.com
# 2. Create an R2 bucket from the dashboard
# 3. Generate API tokens: https://dash.cloudflare.com/profile/api-tokens
# 4. Create a custom token with R2 permissions
# Required scopes: Account → R2 → Read & Write
VITE_R2_ACCOUNT_ID="your-cloudflare-account-id"
VITE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
VITE_R2_ACCESS_KEY_SECRET="your-r2-access-key-secret"
VITE_R2_BUCKET_NAME="your-bucket-name"
VITE_R2_BUCKET_URL="https://your-bucket-name.r2.cloudflarestorage.com"

# ─── Enable Google OAuth in Supabase ─────────────────────────────────────────
# Supabase Dashboard → Authentication → Providers → Google
# Add your Google OAuth Client ID + Secret, then add this callback URL
# in Google Cloud Console → Credentials:
#   https://your-project-ref.supabase.co/auth/v1/callback
# Also add http://localhost:3000/auth/callback to allowed redirect URLs in
# Supabase Dashboard → Authentication → URL Configuration

# ─── Google Sheets (data layer) ──────────────────────────────────────────────
VITE_SPREADSHEET_ID="YOUR_GOOGLE_SPREADSHEET_ID_HERE"

# ─── Sentry Error Monitoring (optional) ──────────────────────────────────────
# 1. Create a Sentry account at https://sentry.io
# 2. Create a new project for your frontend (React)
# 3. Copy the DSN from Project Settings → Client Keys
# Leave empty to disable error monitoring
VITE_SENTRY_DSN=""

# ─── Gemini API (optional – AI features) ─────────────────────────────────────
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# ─── App URL ──────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
