# =============================================================================
# SolarCRM Environment Configuration
# =============================================================================
# For Local Development: Use VITE_USE_MOCK=true to skip external services
# For Production: Fill in actual credentials below
# =============================================================================

# ─── DATABASE (PostgreSQL) - Used by backend ────────────────────────────────
# Only needed if running backend locally or with custom docker-compose
POSTGRES_DB="solarcrm"
POSTGRES_USER="solarcrm_user"
POSTGRES_PASSWORD="change_me_to_strong_password"

# ─── BACKEND API ──────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=4000
VITE_API_URL="http://localhost:3000/api"     # Frontend sees this URL for API

# ─── FRONTEND URLs ────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"               # Public URL of your app

# ─── DATA LAYER: Mock Data vs Google Sheets ───────────────────────────────────
# Set VITE_USE_MOCK=true for development (uses built-in sample data)
# Set VITE_USE_MOCK=false and fill VITE_SPREADSHEET_ID for production
VITE_USE_MOCK="true"
VITE_SPREADSHEET_ID=""

# How to get SPREADSHEET_ID:
# 1. Create a Google Sheet at https://sheets.google.com
# 2. Copy the ID from URL: https://docs.google.com/spreadsheets/d/[THIS_PART]/edit

# ─── SUPABASE (optional) ──────────────────────────────────────────────────────
# Used for real-time features and additional auth options
# Get from https://app.supabase.com/
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key-here"

# ─── CLOUDFLARE R2 STORAGE (optional - file uploads) ──────────────────────────
# Leave blank to use local storage in development
# Production: https://dash.cloudflare.com/ → R2
VITE_R2_ACCOUNT_ID=""
VITE_R2_ACCESS_KEY_ID=""
VITE_R2_ACCESS_KEY_SECRET=""
VITE_R2_BUCKET_NAME=""
VITE_R2_BUCKET_URL=""

# ─── GOOGLE OAUTH (optional - for authentication) ───────────────────────────
# Get from: https://console.cloud.google.com/
# Authorized redirect URIs must include: your-domain/auth/callback
VITE_GOOGLE_CLIENT_ID=""
VITE_GOOGLE_DOMAIN=""

# ─── GEMINI API (optional – AI features) ─────────────────────────────────────
# Get key from: https://ai.google.dev/
# Leave empty to disable AI features
GEMINI_API_KEY=""
