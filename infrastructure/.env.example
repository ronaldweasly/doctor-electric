# =============================================================================
# SolarCRM Production Environment Variables
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL values marked with CHANGEME
# 3. NEVER commit the .env file to git
# 4. Rotate secrets periodically (quarterly minimum)
# =============================================================================

# ─── GENERAL ─────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_NAME=SolarCRM
DOMAIN=crm.yourdomain.com
APP_URL=https://crm.yourdomain.com

# ─── FRONTEND BUILD ARGS ─────────────────────────────────────────────────────
# These are baked into the static build at compile time
VITE_API_URL=https://crm.yourdomain.com/api
VITE_APP_NAME=SolarCRM

# ─── POSTGRESQL ──────────────────────────────────────────────────────────────
# Use a strong, unique password. Generate with: openssl rand -base64 32
POSTGRES_DB=solarcrm
POSTGRES_USER=solarcrm_app
POSTGRES_PASSWORD=CHANGEME_use_openssl_rand_base64_32

# Full connection string (used by backend)
DATABASE_URL=postgresql://solarcrm_app:CHANGEME_use_openssl_rand_base64_32@postgres:5432/solarcrm

# ─── BACKEND API ─────────────────────────────────────────────────────────────
PORT=4000

# JWT secret for session tokens. Generate with: openssl rand -hex 64
JWT_SECRET=CHANGEME_use_openssl_rand_hex_64

# Session configuration
SESSION_EXPIRY=7d
BCRYPT_ROUNDS=12

# CORS - only allow your domain
CORS_ORIGIN=https://crm.yourdomain.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CLOUDFLARE R2 (Object Storage) ─────────────────────────────────────────
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=CHANGEME
R2_ACCESS_KEY_ID=CHANGEME
R2_SECRET_ACCESS_KEY=CHANGEME
R2_BUCKET_NAME=solarcrm-files
R2_PUBLIC_URL=https://files.yourdomain.com

# ─── CLOUDFLARE (DNS/CDN) ───────────────────────────────────────────────────
# Only needed if using Cloudflare API for automated DNS updates
CF_API_TOKEN=CHANGEME
CF_ZONE_ID=CHANGEME

# ─── GOOGLE OAUTH (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGEME
GOOGLE_CLIENT_SECRET=CHANGEME

# ─── GEMINI AI (optional) ───────────────────────────────────────────────────
GEMINI_API_KEY=CHANGEME

# ─── BACKUP ─────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_R2_ENABLED=false
BACKUP_ENCRYPTION_KEY=CHANGEME_use_openssl_rand_hex_32

# ─── MONITORING ─────────────────────────────────────────────────────────────
# Uptime Kuma is accessible at /status (proxied via Nginx)
# Configure alert channels (Telegram, Discord, Email) in the Uptime Kuma UI

# ─── REDIS (future - uncomment when needed) ─────────────────────────────────
# REDIS_PASSWORD=CHANGEME_use_openssl_rand_base64_32
# REDIS_URL=redis://:CHANGEME@redis:6379

# ─── SMTP (for email notifications) ─────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=CHANGEME
# SMTP_PASSWORD=CHANGEME
# SMTP_FROM=noreply@yourdomain.com
